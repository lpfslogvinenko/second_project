PORT=4000
NODE_ENV=development

# Set to 1 to use in-memory Postgres (no Docker) for local dev
USE_PG_MEM=

# PostgreSQL (ignored when USE_PG_MEM=1)
DATABASE_URL=postgres://user:password@localhost:5432/calorie_tracker

# Telegram Bot (from @BotFather) — required for WebApp initData validation
TELEGRAM_BOT_TOKEN=

# Frontend origin(s) for CORS (comma-separated). Telegram Web embed origins
# (web.telegram.org, etc.) are always allowed in addition to these values.
CORS_ORIGIN=http://localhost:5173

# Local browser testing only (never set in production)
ENABLE_DEV_AUTH=

# JWT for API sessions after Telegram auth
JWT_SECRET=change-me-to-a-long-random-string

# Optional: must match setWebhook secret_token for POST /telegram/webhook
TELEGRAM_WEBHOOK_SECRET=
